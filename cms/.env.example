# ── Directus — producción (PostgreSQL en Plesk) ──────────────────────────────
# Copia como .env en el servidor y rellena los valores reales
# Los valores sensibles deben ir como variables del servidor, NO en git

KEY=CAMBIAR_POR_CLAVE_ALEATORIA_32_CHARS
SECRET=CAMBIAR_POR_SECRETO_ALEATORIO_32_CHARS

# PostgreSQL (Plesk crea la base de datos en el panel)
DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=nombre_bbdd
DB_USER=usuario_bbdd
DB_PASSWORD=CAMBIAR_POR_PASSWORD_REAL

# Admin — solo primer arranque
# ⚠️  ELIMINAR ADMIN_TOKEN de producción después del setup inicial
# El token estático solo se ve una vez al generarlo desde el Data Studio
ADMIN_EMAIL=admin@dominio.com
ADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
# ADMIN_TOKEN=        ← Descomentar solo durante setup, luego eliminar

# URLs
PORT=8055
PUBLIC_URL=https://cms.dominio.com

# CORS — dominios del frontend (separados por coma)
# ⚠️  CORS_CREDENTIALS=true es obligatorio si usas session/cookie auth
CORS_ENABLED=true
CORS_ORIGIN=https://www.dominio.com,https://dominio.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PATCH,DELETE
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Tokens — duración
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Storage (local en el servidor)
STORAGE_LOCATIONS=local
STORAGE_LOCAL_ROOT=./uploads

# Email (opcional — Plesk SMTP)
# EMAIL_FROM=noreply@dominio.com
# EMAIL_TRANSPORT=smtp
# EMAIL_SMTP_HOST=localhost
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=

# ⚠️  NO configurar QUERY_LIMIT_DEFAULT=-1 en producción
# Usar limit=-1 explícito solo en queries controladas del frontend
