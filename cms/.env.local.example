# ── Directus — desarrollo local (SQLite, sin dependencias) ──────────────────
# Copia como .env y arranca: npx directus start
# cp .env.local.example .env

KEY=un-secreto-local-cualquier-cosa-32chars
SECRET=otro-secreto-local-cualquier-cosa-32chars

# SQLite — zero dependencias, solo para local
DB_CLIENT=sqlite3
DB_FILENAME=./data.db

# Admin inicial (se crea en el primer arranque)
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=admin1234

# Token estático para el script de setup — debe coincidir con DIRECTUS_TOKEN en setup
# Directus lo crea automáticamente en el primer arranque si se define aquí
ADMIN_TOKEN=dev-admin-token

# Puerto
PORT=8055

# CORS — permite el frontend local (true = cualquier origen en local)
CORS_ENABLED=true
CORS_ORIGIN=true

# URL pública
PUBLIC_URL=http://localhost:8055

# Sin límite por defecto — evita truncado silencioso a 100 ítems en desarrollo
# ⚠️  No usar en producción sin paginación explícita
QUERY_LIMIT_DEFAULT=-1
